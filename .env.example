# NotarVeri Environment Variables
# Copy to Vercel Environment Variables (not committed to repo)

# Signing key – generate with: openssl rand -hex 64
SIGNING_KEY=your_64_character_hex_string_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# API Key for enterprise clients (optional, can be multiple)
API_KEY=test-key-2026
